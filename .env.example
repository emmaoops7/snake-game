# Supabase 配置
# 从 Supabase 项目设置 → API 页面获取以下值

# 项目 URL (格式: https://xxxxxxxxxxxx.supabase.co)
VITE_SUPABASE_URL=your_supabase_url_here

# anon/public key (以 'eyJ' 开头的长字符串)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# 本地开发配置
VITE_APP_NAME=贪吃蛇大作战
VITE_APP_VERSION=1.0.0

# 使用说明：
# 1. 复制此文件为 .env.local
# 2. 填入你的 Supabase 凭证
# 3. 重启开发服务器

# 注意：.env.local 文件不会被提交到 Git，保护你的密钥安全